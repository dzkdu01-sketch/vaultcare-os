# 设为 false 切换到真实 API
VITE_USE_MOCK=true

# 后端 API 基础地址（须含 /api/v1 前缀，与 Express 挂载一致）
# 开发：可用相对路径走 Vite 代理，或直连后端 http://localhost:3002/api/v1
VITE_API_BASE_URL=/api/v1

# 商品描述预览：媒体 URL 额外允许的域名（逗号分隔，会与内置白名单合并）
# VITE_MEDIA_HOST_WHITELIST=cdn.example.com

# /lookbook WhatsApp 号码：国家码 + 国内号码，无 + 号（例：阿联酋 971501234567）
# VITE_WHATSAPP_E164=971501234567
