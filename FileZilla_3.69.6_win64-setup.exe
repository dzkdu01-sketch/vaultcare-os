            <div id="rightad-spacer"></div>
            <div id="rightad">
              <div>
                <p>Advertisement:</p>
                <a id="rightad-link" href="" rel="nofollow">
                  <img id="rightad-image" width="130" height="100" src="" alt="Advertisement"></img>
                  <p id="rightad-caption" href="" rel="nofollow"></p>
                </a>
              </div>
            </div>

<script type="text/javascript">//<![CDATA[
  document.addEventListener('DOMContentLoaded', function(event){
    if (window.getComputedStyle(document.getElementById('rightad')).display == "none") {
      return;
    }
    var xhr = new XMLHttpRequest();
    xhr.onreadystatechange = function (e) {
      if (xhr.readyState == 4 && xhr.status == 200) {
        document.getElementById('rightad-link').setAttribute('href', xhr.getResponseHeader("x-ad-link"));
        document.getElementById('rightad-image').src = window.URL.createObjectURL(new Blob([xhr.response]));
        document.getElementById('rightad-image').title = xhr.getResponseHeader("x-ad-title");
        document.getElementById('rightad-caption').innerHTML = xhr.getResponseHeader("x-ad-title");
        document.getElementById('rightad').style.visibility = "visible";
      }
    };
    xhr.open("POST", "https://ads.filezilla-project.org/rightad.php", true);
    xhr.responseType = "arraybuffer"; // ie11...
    xhr.send();
  });
  //]]></script>

