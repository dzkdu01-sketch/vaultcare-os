# Django
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=.up.railway.app,localhost,127.0.0.1

# Database
# Railway PostgreSQL will provide DATABASE_URL automatically.
# For local development, you can keep using sqlite by not setting this value.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS/CSRF
# Frontend domain (Vercel temporary domain or your custom domain)
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app

# Optional AI key
# CLAUDE_API_KEY=
